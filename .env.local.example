# ── Root env for the Next.js app (copy to .env.local) ──────────────────────
# .env.local is gitignored, so your real keys never get committed.

# Postgres (Neon works great free). Required for the CRM to persist leads.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── AI brain (optional but highly recommended) ─────────────────────────────
# Drop ONE of these and the app auto-powers AI scoring + intent server-side,
# no Settings-UI setup needed. Precedence: groq > nim > openai > gemini.

# Groq — fastest, generous free tier. https://console.groq.com/keys
groq_api_key=
# groq_model=llama-3.3-70b-versatile

# NVIDIA NIM — free Llama hosting. https://build.nvidia.com
nim_key=
# nim_model=meta/llama-3.1-8b-instruct

# Also supported if you prefer:
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# NOTE: search/scraping keys (Serper, Reddit, ProductHunt) live in
# python_engine/.env — see python_engine/.env.example.
