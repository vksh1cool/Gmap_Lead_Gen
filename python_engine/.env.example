# Copy this file to `python_engine/.env` and fill in the keys you have.
# Everything is optional — the engine degrades gracefully — but each key you add
# makes a platform reliable and ban-proof. Restart uvicorn after editing.

# ── Search backend for LinkedIn / Instagram / Quora / Upwork dorking ──
# Serper.dev — 2,500 free queries, no credit card. https://serper.dev (Settings → API Key)
# This is the single highest-leverage key: it makes ALL dork platforms reliable.
SERPER_API_KEY=

# Optional alternative search backends (used only if SERPER_API_KEY is empty):
# BRAVE_API_KEY=
# GOOGLE_CSE_KEY=
# GOOGLE_CSE_CX=
# SEARXNG_URL=https://your-searxng-instance

# ── Reddit (rich native API; otherwise falls back to dorking) ──
# Free app at https://www.reddit.com/prefs/apps  → create a "script" or "installed" app.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=python:gmaps-lead-scraper:1.0 (by /u/yourname)

# ── ProductHunt (native GraphQL API; otherwise falls back to dorking) ──
# Free developer token at https://www.producthunt.com/v2/oauth/applications
PRODUCTHUNT_TOKEN=

# ── X / Twitter (Nitter mirrors; override if the defaults are down) ──
# NITTER_INSTANCES=https://nitter.privacyredirect.com,https://nitter.net

# ── OpenStreetMap Places source (free, no key, default local-business source) ──
# Nominatim's usage policy asks for a genuine, identifying User-Agent. Set your
# contact so the free tier stays available to you (this is compliance, not
# tracking). See COMPLIANCE.md §5.
# OSM_CONTACT=you@yourdomain.com
# OSM_USER_AGENT=YourApp/1.0 (you@yourdomain.com)
